# Production API base (e.g. https://your-backend.onrender.com/api). Omit for local dev (/api via Vite proxy).
VITE_API_BASE_URL=

# Production Socket.IO server (e.g. https://your-backend.onrender.com). Omit for local dev (same-origin via Vite proxy).
VITE_SOCKET_URL=

# Backend origin for uploaded avatars (e.g. https://your-backend.onrender.com). Omit for local dev.
VITE_API_ORIGIN=

# Google Identity Services — OAuth 2.0 Web client ID
VITE_GOOGLE_CLIENT_ID=
